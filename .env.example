# 请将此文件重命名为 .env，并填入你的实际 API Key
# 注意：.env 文件已被 .gitignore 忽略，不会被提交到 Git 仓库，请放心填写

# MiniMax API 密钥
MINIMAX_API_KEY=sk-请在这里填入你的MiniMax密钥

# Hermes Local Provider 配置
# 说明：
# 1. 调试阶段默认建议使用 Hermes 的 coder profile
# 2. 优先级：显式 HERMES_BASE_URL / HERMES_API_KEY > 首选 profile .env > 自动扫描其他 profile
# 3. 如果不填 HERMES_PROFILE_ENV_FILE，则默认先读取 ~/.hermes/profiles/<profile>/.env
# 4. 若首选 profile 不可用，OpenCopilot 会自动扫描 ~/.hermes/profiles/*/.env 并验证健康实例
HERMES_PROVIDER_PROFILE=coder
HERMES_PROFILE_ENV_FILE=
HERMES_BASE_URL=
HERMES_API_KEY=
