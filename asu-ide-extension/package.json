{
  "name": "asu-ide-extension",
  "displayName": "ASU IDE Companion",
  "description": "Companion extension for ASU (Advanced System Utilities) to provide local IDE context.",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "asu-ide-extension.startServer",
        "title": "ASU: Start Local Context Server"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "package": "vsce package",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "@types/vscode": "^1.70.0",
    "vsce": "^2.15.0"
  }
}
