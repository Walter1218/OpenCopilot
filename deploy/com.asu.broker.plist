<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

    <!-- === 唯一标识符 === -->
    <key>Label</key>
    <string>com.asu.broker</string>

    <!-- === 启动命令 ===
         install_broker_daemon.sh 安装时会自动将 __XXX__ 占位符替换为实际路径 -->
    <key>ProgramArguments</key>
    <array>
        <string>__PYTHON_EXECUTABLE__</string>
        <string>run.py</string>
    </array>

    <!-- === 工作目录（必须为 asu_broker/ 目录，因为 run.py 使用相对导入）=== -->
    <key>WorkingDirectory</key>
    <string>__ASU_PROJECT_DIR__/asu_broker</string>

    <!-- === 开机自启 === -->
    <key>RunAtLoad</key>
    <true/>

    <!-- === 崩溃自动重启（间隔 5 秒，防止快速重启风暴）=== -->
    <key>KeepAlive</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>5</integer>

    <!-- === 日志路径（标准输出 & 错误输出）=== -->
    <key>StandardOutPath</key>
    <string>__HOME__/Library/Logs/ASU/broker_out.log</string>

    <key>StandardErrorPath</key>
    <string>__HOME__/Library/Logs/ASU/broker_err.log</string>

    <!-- === 环境变量（确保 Python 路径和 Token 正确）=== -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>__PYTHON_BIN_DIR__:/usr/local/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>__HOME__</string>
    </dict>

</dict>
</plist>
