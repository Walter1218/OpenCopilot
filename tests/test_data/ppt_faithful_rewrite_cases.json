{
  "benchmark_name": "ppt_faithful_rewrite",
  "version": "2026-06-11",
  "description": "Benchmark cases for evaluating faithful rewrite ability in PPT co-creation. Focus on professionalization without factual drift.",
  "dimensions": [
    "fact_retention",
    "structure_preservation",
    "professional_expression",
    "hallucination_control"
