      "case_id": "fr_001",
      "category": "F_polish",
      "label": "数字与术语保留",
      "doc_key": "business_proposal",
      "current_index": 2,
      "instruction": "润色当前页文案，让表达更专业，但必须保留所有数字、专业术语和价格信息，不能新增卖点，也不能调整条目顺序。",
      "focus": ["fact_retention", "professional_expression"],
      "hard_constraints": ["保留数字", "保留专业术语", "顺序不变", "不可新增事实"],
      "expected_failure_patterns": ["价格被模糊", "条目顺序被重排", "新增原文没有的卖点"]
